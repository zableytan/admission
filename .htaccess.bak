# Security .htaccess for DMSF Admission System
# Prevent directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Protect database and configuration files
<FilesMatch "\.(sql|env|ini|conf|bak|old)$">
    Require all denied
</FilesMatch>

# Protect log files
<FilesMatch "\.(log)$">
    Require all denied
</FilesMatch>

# Protect vendor directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^vendor/ - [F,L]
</IfModule>

# Prevent access to hidden files and directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/\. [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Enable XSS protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove server signature
    Header always unset X-Powered-By
</IfModule>

# File upload security
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|cgi|pl|exe)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Allow PHP only in root directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Prevent PHP execution in uploads directory
    RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|php7|phps|cgi|pl|exe)$ - [F,L]
    
    # Prevent PHP execution in scratch directory
    RewriteRule ^scratch/.*\.(php|phtml|php3|php4|php5|php7|phps|cgi|pl|exe)$ - [F,L]
    
    # Prevent PHP execution in sql directory
    RewriteRule ^sql/.*\.(php|phtml|php3|php4|php5|php7|phps|cgi|pl|exe)$ - [F,L]
</IfModule>

# Limit file upload size (10MB)
# LimitRequestBody 10485760

# Cache control for security-sensitive files
<FilesMatch "\.(pdf|doc|docx|xls|xlsx)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Force HTTPS (uncomment if you have SSL)
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
